################################################################################
# Archivo de ejemplo de variables de entorno para Lucy App
# Copiar como `.env` y ajustar según el entorno.
#
# cp .env.example .env
################################################################################

#######################################
# MODO DE EJECUCIÓN
#######################################
# DEVEL=1  → Modo desarrollo (debug, API mock o ngrok)
# DEVEL=0  → Modo producción
DEVEL=1


#######################################
# BASE DE DATOS (EJEMPLO POSTGRES)
#######################################
#DB_NAME=lucy
#DB_USER=lucy
#DB_PASSWORD=lucypass
#DB_HOST=localhost
#DB_PORT=5432

DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=app
DB_PASS=app



#######################################
# API UTI — CONFIGURACIÓN DEL BASE_URL
#######################################
# En desarrollo local usando mock (docker-compose o python)
#UTI_API_BASE_URL=http://localhost:8001

# Si estás usando ngrok para exponer el mock o la UTI real:
# Copiar la URL que genere ngrok, por ejemplo:
#UTI_API_BASE_URL=https://pepito-1234.ngrok-free.dev

# En producción, apuntar a la API real de la UTI (predefinido en settings)
UTI_API_BASE_URL=https://uti.unrc.edu.ar


#######################################
# SECRET KEY PARA DJANGO
#######################################
# Cambiar por una clave segura en cada instalación.
DJANGO_SECRET_KEY=CHANGE_ME_1234567890


#######################################
# DEBUG DJANGO
#######################################
# En producción debe ser 0
DJANGO_DEBUG=1


#######################################
# ALLOWED HOSTS
#######################################
# Django ignora espacios y separa por comas
# Usar .ngrok-free.dev para permitir todos los túneles
ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok-free.dev

